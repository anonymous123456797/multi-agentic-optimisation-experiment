```python
import math

def largest_prime_factor(n):
    """
    Finds the largest prime factor of a given number n.

    Args:
        n: An integer (n >= 2).

    Returns:
        The largest prime factor of n.
    """
    if n < 2:
        raise ValueError("Input must be an integer greater than or equal to 2.")

    max_prime = -1

    # Handle factor 2 separately
    while n % 2 == 0:
        max_prime = 2
        n //= 2  # Use integer division

    # n must be odd at this point. So we can skip even numbers and iterate by 2.
    # We only need to check divisors up to sqrt(n)
    for i in range(3, int(math.sqrt(n)) + 1, 2):
        # While i divides n, update max_prime and divide n
        while n % i == 0:
            max_prime = i
            n //= i  # Use integer division

    # If n is still greater than 2 after all divisions,
    # it means the remaining n is a prime number itself and must be the largest.
    if n > 2:
        max_prime = n

    return max_prime

